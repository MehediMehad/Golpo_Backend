generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  image    String?
  email    String  @unique
  password String?

  provider   JoinedProviderEnum
  providerId String
  role       RoleEnum           @default(USER)
  status     UserStatusEnum     @default(ACTIVE)

  isDeleted Boolean  @default(false)
  joinedAt  DateTime @default(now())
  loginAt   DateTime @updatedAt

  @@map("users")
}

enum JoinedProviderEnum {
  google
  github
  facebook
}

enum RoleEnum {
  USER
  ADMIN
}

enum UserStatusEnum {
  ACTIVE
  BLOCKED
}
